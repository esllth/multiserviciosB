@page
@model LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <title>Login</title>
</head>

<body>

    <div class="login-page">

        <div class="login-header">
            <img src="~/images/logo.png" />
            <a asp-page="./Register">Registrarse</a>
        </div>

        <div class="login-left">
            <div class="login-box">

                <h2>Bienvenido</h2>
                <p>Inicia sesión para cotizar servicios.</p>

                <form method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="Correo" />
                        <label asp-for="Input.Email">Correo</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" placeholder="Contraseña" />
                        <label asp-for="Input.Password">Contraseña</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Iniciar sesión
                    </button>

                </form>

            </div>
        </div>

        <div class="login-right"></div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</body>
</html>