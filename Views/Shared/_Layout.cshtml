<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Multiservicio Bolivar</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="layout-body">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light custom-navbar fixed-top">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" style="height:50px;" alt="Logo Multiservicio Bolivar" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                            </li>

                            if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Empleados" asp-action="Index">Empleados</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tecnicos" asp-action="Tecnicos">Técnicos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Materiales" asp-action="Materiales">Materiales</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Equipos" asp-action="Equipos">Equipos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="FabricacionAmedida" asp-action="FabricacionAmedida">Fabricación</a>
                                </li>
                            }

                            if (User.IsInRole("Empleado"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tecnicos" asp-action="Tecnicos">Mis Servicios</a>
                                </li>
                            }
                        }

                    </ul>

                    <div class="ms-auto">
                        <partial name="_LoginPartial" />
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>© 2026 - Multiservicio Bolivar</p>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>