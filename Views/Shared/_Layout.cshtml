<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Multiservicio Bolivar</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- YOUR GLOBAL CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/MultiservicioBolivar.styles.css" asp-append-version="true" />
</head>

<body class="layout-body">

    <!-- ============================
         🧭 NAVBAR (GLOBAL)
    ============================ -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light custom-navbar fixed-top">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" style="height:40px; margin-right:10px;" />
                    <span>Multiservicio Bolivar</span>
                </a>

                <!-- MOBILE BUTTON -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- NAV CONTENT -->
                <div class="navbar-collapse collapse justify-content-center">

                    <ul class="navbar-nav">

                        <!-- PUBLIC -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                        </li>

                        @* ============================
                           🔐 AUTHENTICATION LOGIC
                        ============================ *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @* ============================
                               👑 ADMIN ACCESS
                            ============================ *@
                            if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                        Admin Panel
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Empleados" asp-action="Index">
                                        Empleados
                                    </a>
                                </li>
                            }

                            @* ============================
                               👷 EMPLOYEE (FUTURE ROLE)
                               👉 You can later change logic here
                            ============================ *@
                            else if (User.IsInRole("Empleado"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Application" asp-action="Index">
                                        Gestión
                                    </a>
                                </li>
                            }

                            @* ============================
                               👤 NORMAL USER
                            ============================ *@
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Application" asp-action="Create">
                                        Crear Cotización
                                    </a>
                                </li>
                            }
                        }

                    </ul>

                    <!-- LOGIN / LOGOUT -->
                    <div class="ms-auto">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- ============================
         🧱 MAIN CONTENT
    ============================ -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- ============================
         🧱 FOOTER (FIXED STRUCTURE)
    ============================ -->
    <footer class="footer">
        <p>© 2026 - Multiservicio Bolivar</p>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>