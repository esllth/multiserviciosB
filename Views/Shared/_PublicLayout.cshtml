<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Multiservicio Bolívar</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR PUBLICO -->
    <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm fixed-top">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" style="height:50px;" alt="Multiservicio Bolívar" />
            </a>

            <div class="ms-auto">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary me-2">
                    Iniciar Sesión
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">
                    Registrarse
                </a>
            </div>

        </div>
    </nav>

    <!-- CONTENIDO -->
    <main class="container" style="margin-top: 100px; min-height: calc(100vh - 200px);">
        @RenderBody()
    </main>

    <footer class="text-center mt-5 py-3 bg-light">
        <p class="mb-0 text-muted">© 2026 - Multiservicio Bolívar. Todos los derechos reservados.</p>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>