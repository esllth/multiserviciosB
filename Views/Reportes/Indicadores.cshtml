    <div class="row text-center">
        <div class="col-md-4">
            <div class="card bg-warning text-white p-3">
                <h4>Pendientes</h4>
                <h2>12</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white p-3">
