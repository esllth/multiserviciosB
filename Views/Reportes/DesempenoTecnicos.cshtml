@{
    ViewData["Title"] = "Desempeño de Técnicos";
}

<div class="container mt-4">
    <h2>Reporte de Desempeño</h2>

    <div class="mb-3">
        <label>Seleccionar Técnico</label>
        <select class="form-control">
            <option>Carlos López</option>
            <option>Ana Rodríguez</option>
        </select>
    </div>

    <div class="card p-3 mb-3">
        <h5>Servicios Realizados</h5>
        <ul>
            <li>Instalación - 10 servicios</li>
            <li>Mantenimiento - 7 servicios</li>
        </ul>
    </div>

    <div class="card p-3 mb-3">
        <h5>Tiempo Promedio de Atención</h5>
        <p>2.5 horas</p>
    </div>

    <div class="card p-3">
        <h5>Calificación Promedio</h5>
        <p>4.6 / 5</p>
    </div>
</div>
