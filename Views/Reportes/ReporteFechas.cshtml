@{
    ViewData["Title"] = "Reporte por Fechas";
}

<div class="container mt-4">
    <h2>Reporte de Órdenes por Fecha</h2>

    <form class="row g-3 mb-4">
        <div class="col-md-4">
            <label>Fecha Inicio</label>
            <input type="date" class="form-control" />
        </div>
        <div class="col-md-4">
            <label>Fecha Fin</label>
            <input type="date" class="form-control" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button class="btn btn-primary">Generar Reporte</button>
        </div>
    </form>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Técnico</th>
                <th>Estado</th>
                <th>Tipo Servicio</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Juan Pérez</td>
                <td>Carlos López</td>
                <td>Completado</td>
                <td>Mantenimiento</td>
            </tr>
            <tr>
                <td>María Gómez</td>
                <td>Ana Rodríguez</td>
                <td>En proceso</td>
                <td>Instalación</td>
            </tr>
        </tbody>
    </table>
</div>