@{
    ViewData["Title"] = "Inicio";
}

<!-- ============================
     🎠 HERO / CARRUSEL
============================ -->
<div id="carouselExample" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="~/images/slide1.jpg" class="d-block w-100" alt="Slide 1">
                <div class="carousel-caption d-none d-md-block">
                    <h2>Multiservicio Bolívar</h2>
                    <p>Soluciones confiables para tu negocio</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="~/images/slide2.jpg" class="d-block w-100" alt="Slide 2">
                    <div class="carousel-caption d-none d-md-block">
                        <h2>Calidad y compromiso</h2>
                        <p>Trabajamos contigo</p>
                    </div>
                </div>

                <div class="carousel-item">
                    <img src="~/images/slide3.jpg" class="d-block w-100" alt="Slide 3">
                    </div>

                </div>

                <!-- Controles -->
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>


            <!-- ============================
     🧾 BIENVENIDA GENERAL
============================ -->
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold">Bienvenido a Multiservicio Bolívar</h1>
                <p class="lead">Gestión eficiente de servicios y solicitudes</p>
            </div>


            <!-- ============================
     🔐 USUARIO AUTENTICADO
============================ -->
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="container">

                    <!-- ============================
             👑 ADMIN
        ============================ -->
                    @if (User.IsInRole("Administrador"))
                    {
                        <div class="card shadow-sm mb-4 p-4 text-center">
                            <h3 class="mb-3">Panel de Administración</h3>
                            <p>Gestiona empleados, solicitudes y sistema.</p>

                            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
                                Ir al Panel
                            </a>
                        </div>

                        <!-- 🔥 ESPACIO FUTURO ADMIN -->
                        <div class="card p-4 text-center">
                            <h5>📊 Módulos futuros</h5>
                            <p>Aquí podrás agregar reportes, métricas, dashboards, etc.</p>
                        </div>
                    }

                    <!-- ============================
             👤 USUARIO NORMAL
        ============================ -->
                    else
                    {
                    <div class="row g-4">

                        <div class="col-md-6">
                            <div class="card p-4 text-center shadow-sm">
                                <h5>Crear Solicitud</h5>
                                <p>Registra una nueva solicitud de servicio.</p>

                                <a asp-controller="Application" asp-action="Create" class="btn btn-primary">
                                    Crear
                                </a>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card p-4 text-center shadow-sm">
                                <h5>Mis Solicitudes</h5>
                                <p>Consulta el estado de tus solicitudes.</p>

                                <a asp-controller="Application" asp-action="MyApplication" class="btn btn-primary">
                                    Ver
                                </a>
                            </div>
                        </div>

                    </div>

                    <!-- 🔥 ESPACIO FUTURO USER -->
                    <div class="card mt-4 p-4 text-center">
                        <h5>✨ Próximamente</h5>
                        <p>Aquí puedes agregar historial, notificaciones o seguimiento en tiempo real.</p>
                    </div>
                    }

                </div>
            }
            else
            {
                <!-- ============================
         🚪 USUARIO NO LOGUEADO
    ============================ -->
                <div class="text-center mt-5">
                    <h4>Accede al sistema</h4>
                    <p>Inicia sesión para gestionar tus servicios.</p>

                    <a href="/Identity/Account/Login" class="btn btn-primary">
                        Iniciar Sesión
                    </a>
                </div>
            }