@{
    ViewData["Title"] = "Configuración";
}

<div class="container mt-5">
    <h2 class="mb-4">Configuración del Sistema</h2>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>Horario Laboral</h5>
                    <input class="form-control" value="08:00 - 18:00" />
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>Zonas de Cobertura</h5>
                    <input class="form-control" value="San José, Heredia" />
                </div>
            </div>
        </div>
    </div>

    <div class="text-end">
        <button class="btn btn-primary px-4">Guardar Cambios</button>
    </div>
</div>